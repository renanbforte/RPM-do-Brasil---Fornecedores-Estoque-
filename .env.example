# ==========================================================
# Banco de dados — SQLite (arquivo único)
# Caminho relativo à raiz do projeto ou absoluto.
# ==========================================================
DB_PATH=./data/estoque.db

# ==========================================================
# API da OpenAI (usada na etapa de normalização via LLM)
# ==========================================================
OPENAI_API_KEY=coloque_sua_chave_aqui
OPENAI_MODEL=gpt-4o-mini

# ==========================================================
# Pipeline de ingestão
# ==========================================================
# Pasta local que simula o Google Drive nesta fase
PASTA_ENTRADA=./data/entrada

# ---- API de consulta ----
# Token exigido no header Authorization: Bearer <token>
API_TOKEN=troque-por-um-token-forte
# Caminho do banco para a API (somente-leitura). Vazio = usa o DB_PATH acima.
# No servidor (EasyPanel) costuma ser algo como /data/estoque.db
DATABASE_PATH=
# URL pública da API — usada por scripts/publicar.py e scripts/atualizar.py
# para enviar o .db pronto ao servidor (deixe vazio no próprio servidor)
API_BASE_URL=

# ---- Google Drive (fonte de produção) ----
# Fonte dos arquivos: "local" (pasta PASTA_ENTRADA) ou "drive"
FONTE=local
# ID da pasta no Drive (parte final da URL .../folders/<ID>)
GDRIVE_FOLDER_ID=
# Credencial da conta de serviço — escolha UMA das formas:
#  (a) arquivo local:
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service_account.json
#  (b) o JSON inteiro em base64 (recomendado no EasyPanel — 1 linha, sem arquivo):
# GOOGLE_CREDENTIALS_BASE64=
#  (c) o JSON cru numa variável:
# GOOGLE_CREDENTIALS_JSON=
